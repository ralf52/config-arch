# Example line in ~/.config/kitty/kitty.conf
background_opacity 0.9

# Incluir la paleta generada por pywal
include ~/.cache/wal/colors-kitty.conf

# Opcional: otras configuraciones
cursor_shape beam
scrollback_lines 10000
# Habilitar campana con sonido personalizado
enable_audio_bell no
command_on_bell paplay ~/.config/kitty/sounds/bong_pvz.mp3

#animacion cursor flash
cursor_trail 10
cursor_trail_start_threshold 0
cursor_trail_start_decay 0.01 0.05
cursor_shape block
cursor_blink true


# BEGIN_KITTY_FONTS
font_family      family="FiraMono Nerd Font"
font_size        11.0
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
