#!/bin/bash

# Define menu entries with Nerd Fonts icons
# Find more icons at: https://www.nerdfonts.com/cheat-sheet[citation:3]
entries="’Ćæ  Apagar\n’Ć×  Reiniciar\n’ĆŻ  Bloquear\n’łČ  Suspender\n’Ćć  Cerrar Session"

# Use wofi as a dmenu to show the options
chosen=$(echo -e "$entries" | wofi --dmenu --prompt="Power Menu:")

# Execute the chosen action
case "$chosen" in
"’Ćæ  Apagar")
  systemctl poweroff
  ;;
"’Ć×  Reiniciar")
  systemctl reboot
  ;;
"’ĆŻ  Bloquear")
  # Replace with your locker command (e.g., hyprlock, swaylock)
  hyprlock
  ;;
"’łČ  Suspender")
  systemctl suspend
  ;;
"’Ćć  Cerrar Session")
  # Exits the Hyprland session
  hyprctl dispatch exit
  ;;
esac
