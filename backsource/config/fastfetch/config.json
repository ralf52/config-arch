{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    
    "modules": [
        {
            "type": "custom",
            "format": "\n\n\n\n\n\n\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ",
            "key": "top_border"
        },
        {
            "type": "os",
            "format": "\\n \\n п…ј {1}",
            "key": "Distro"
        },
        {
            "type": "host",
            "format": "\\n \\n пӢҒ {2}",
            "key": "Model"
        },
        {
            "type": "kernel",
            "format": "\\n \\n п‘і {1}",
            "key": "Kernel"
        },
        {
            "type": "uptime",
            "format": "\\n \\n оҺ… {1}",
            "key": "Uptime"
        },
        {
            "type": "packages",
            "format": "\\n \\n у°Ҹ— {1}",
            "key": "Packages"
        },
        {
            "type": "shell",
            "format": "\\n \\n п„  {1}",
            "key": "Shell"
        },
        {
            "type": "theme",
            "format": "\\n \\n у°”Һ {1}",
            "key": "Theme"
        },
        {
            "type": "terminal",
            "format": "\\n \\n п’ү {1}",
            "key": "Terminal"
        },
        {
            "type": "terminalfont",
            "format": "\\n \\n пҖұ {1}",
            "key": "TerminalFont"
        },
        {
            "type": "cpu",
            "format": "\\n \\n п‘Ј {1}",
            "key": "CPU"
        },
        {
            "type": "gpu",
            "format": "\\n \\n у°Ҡҡ {1}",
            "key": "GPU"
        },
        {
            "type": "memory",
            "format": "\\n \\n пҲҖ {1}",
            "key": "Memory"
        },
        {
            "type": "disk",
            "format": "\\n \\n пӮ  {1}",
            "key": "Disk"
        },
        {
            "type": "music",
            "format": "\\n \\n пҶј {1}",
            "key": "Song"
        },
        {
            "type": "custom",
            "format": "\\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ пҖҚ пҖҚ пҖҚ пҖҚ пҖҚ пҖҚ пҖҚ пҖҚ в”ҳ\\n",
            "key": "bottom_border"
        }
    ],

    "display": {
        "separator": " ",
        "keyColor": "gray",
        "keySuffix": "",
        "separatorColor": "gray"
    },

    "logo": {
        "type": "none"
    },

    "general": {
        "multithreading": true,
        "showErrors": false,
        "loadConfigPrompt": false
    },

    "os": {
        "format": "{2}",
        "verbose": false
    },

    "kernel": {
        "key": "Kernel",
        "format": "{1}"
    },

    "uptime": {
        "format": "{1}"
    },

    "packages": {
        "format": "{1}",
        "showLegend": true
    },

    "shell": {
        "format": "{1}",
        "showVersion": true,
        "showPath": false
    },

    "cpu": {
        "showCores": "logical",
        "showTemperature": false,
        "showFrequency": true,
        "frequencyType": "bios",
        "showMaxFrequency": false,
        "showBrand": true,
        "format": "{1}"
    },

    "gpu": {
        "showType": "all",
        "showBrand": true,
        "format": "{1}"
    },

    "memory": {
        "showPercentage": true,
        "unit": "mib",
        "format": "{1}"
    },

    "disk": {
        "showType": "mounted",
        "showTotal": true,
        "showUsed": true,
        "showFree": false,
        "showPercentage": true,
        "disks": ["/storage/emulated", "/", "/server"],
        "format": "{1}",
        "legend": "none"
    },

    "music": {
        "player": "auto",
        "format": "{artist} - {album} - {title}",
        "maxLength": 0
    }
}
